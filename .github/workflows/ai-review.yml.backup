# AI Code Review & Quality Gate
# 自动执行：测试门禁 + 架构一致性 + 安全检查

name: AI Quality Gate

on:
  push:
    branches: [main, master, develop]
  pull_request:
    branches: [main, master, develop]

jobs:
  ai-quality-gate:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0  # 获取完整历史用于增量检查
      
      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.10"
          cache: "pip"
      
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install ruff mypy
          if [ -f requirements.txt ]; then
            pip install -r requirements.txt
          fi
      
      - name: Get changed files (incremental)
        id: changed
        run: |
          if [ "${{ github.event_name }}" == "pull_request" ]; then
            echo "files=$(git diff --name-only ${{ github.event.pull_request.base.sha }}..${{ github.event.pull_request.head.sha }} | tr '\n' ',')" >> $GITHUB_OUTPUT
          else
            echo "files=$(git diff --name-only HEAD~1 HEAD | tr '\n' ',')" >> $GITHUB_OUTPUT
          fi
      
      - name: Run Trea Hook (Incremental Test)
        id: test
        run: |
          if [ -n "${{ steps.changed.outputs.files }}" ]; then
            python trea_hook.py --incremental --files "${{ steps.changed.outputs.files }}"
          else
            echo "No changed files, skipping test"
          fi
        continue-on-error: true
      
      - name: Run Architecture Guard
        id: arch
        run: |
          python .claw/arch_guard.py --format json > /tmp/arch_result.json || true
          cat /tmp/arch_result.json
        continue-on-error: true
      
      - name: Run Security Scan
        id: security
        run: |
          python scripts/security_scan.py --format json > /tmp/security_result.json || true
          cat /tmp/security_result.json
        continue-on-error: true
      
      - name: Run Lint (Ruff)
        id: lint
        run: |
          if [ -n "${{ steps.changed.outputs.files }}" ]; then
            ruff check ${{ steps.changed.outputs.files }} --output-format json > /tmp/lint_result.json || true
          else
            echo "No changed files, skipping lint"
          fi
        continue-on-error: true
      
      - name: Generate Summary
        if: always()
        run: |
          echo "## 🛡️ AI Quality Gate Result" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "| Check | Status | Details |" >> $GITHUB_STEP_SUMMARY
          echo "|-------|--------|---------|" >> $GITHUB_STEP_SUMMARY
          
          test_status="${{ steps.test.outcome }}"
          arch_status="${{ steps.arch.outcome }}"
          security_status="${{ steps.security.outcome }}"
          lint_status="${{ steps.lint.outcome }}"
          
          echo "| Test Gate | $([ "$test_status" == "success" ] && echo "✅ Passed" || echo "⚠️ Failed") | [View Logs](#) |" >> $GITHUB_STEP_SUMMARY
          echo "| Arch Guard | $([ "$arch_status" == "success" ] && echo "✅ Passed" || echo "⚠️ Failed") | [View Logs](#) |" >> $GITHUB_STEP_SUMMARY
          echo "| Security | $([ "$security_status" == "success" ] && echo "✅ Passed" || echo "⚠️ Failed") | [View Logs](#) |" >> $GITHUB_STEP_SUMMARY
          echo "| Lint | $([ "$lint_status" == "success" ] && echo "✅ Passed" || echo "⚠️ Failed") | [View Logs](#) |" >> $GITHUB_STEP_SUMMARY
          
          if [ "$test_status" == "success" ] && [ "$arch_status" == "success" ] && [ "$security_status" == "success" ] && [ "$lint_status" == "success" ]; then
            echo "" >> $GITHUB_STEP_SUMMARY
            echo "### ✅ All checks passed! Ready to merge." >> $GITHUB_STEP_SUMMARY
          else
            echo "" >> $GITHUB_STEP_SUMMARY
            echo "### ⚠️ Some checks failed. Please review and fix." >> $GITHUB_STEP_SUMMARY
          fi
      
      - name: Upload Artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: quality-gate-results
          path: |
            /tmp/arch_result.json
            /tmp/security_result.json
            /tmp/lint_result.json
          retention-days: 7
