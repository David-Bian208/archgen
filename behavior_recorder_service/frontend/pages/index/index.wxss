/* pages/index/index.wxss */
.container {
  padding: 40rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

/* 标题区域 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #7f8c8d;
  margin-top: 16rpx;
  display: block;
}

/* 输入区域 */
.input-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.input-box {
  width: 100%;
  min-height: 300rpx;
  padding: 24rpx;
  font-size: 32rpx;
  line-height: 1.6;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
  background: #fafafa;
}

.send-btn {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 28rpx;
  font-weight: bold;
}

.send-btn[disabled] {
  background: #ccc;
}

/* 加载动画 */
.loading {
  text-align: center;
  padding: 100rpx 0;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 32rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #7f8c8d;
}

/* 报告卡片 */
.report-section {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.report-card {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 24rpx;
}

.card-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #34495e;
}

/* 免责声明 */
.disclaimer {
  background: #fff3cd;
  border-left: 6rpx solid #ffc107;
  padding: 32rpx;
  border-radius: 8rpx;
}

.disclaimer-text {
  font-size: 26rpx;
  color: #856404;
  line-height: 1.6;
}

/* 反馈区域 */
.feedback-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.feedback-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  text-align: center;
  margin-bottom: 32rpx;
}

/* 星级评分 */
.rating {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.star {
  font-size: 60rpx;
  color: #e0e0e0;
  transition: all 0.3s;
}

.star.active {
  color: #ffc107;
}

/* 准确性选择 */
.accuracy-selector {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.accuracy-btn {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  border: 2rpx solid #ddd;
  background: white;
  border-radius: 8rpx;
}

.accuracy-btn.active {
  background: #667eea;
  color: white;
  border-color: #667eea;
}

/* 反馈输入 */
.feedback-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
  background: #fafafa;
  margin-bottom: 32rpx;
}

.submit-feedback {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 24rpx;
  font-weight: bold;
}

/* 新记录按钮 */
.new-record-btn {
  margin-top: 32rpx;
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 24rpx;
  font-weight: bold;
}
