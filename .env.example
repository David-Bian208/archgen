# 排布 (PaiBu) 环境变量模板
# 复制为 .env 并填写实际值

# DeepSeek API 密钥（必填）
DEEPSEEK_API_KEY=sk-xxxxx

# LLM 配置（可选，默认值如下）
# PAIBU_LLM_BASE_URL=https://api.deepseek.com/v1
# PAIBU_LLM_MODEL=deepseek-v4-flash
# PAIBU_LLM_TIMEOUT=120

# 服务配置（可选）
# PAIBU_HOST=0.0.0.0
# PAIBU_PORT=8090

# 是否使用真实 LLM（默认 true）
USE_REAL_LLM=true
