# Behavior Recorder Service 配置文件
# 复制此文件为 config.yaml 并填入您的真实配置

# LLM 配置
llm:
  # 提供商（当前仅支持 openai 兼容接口）
  provider: "openai"
  
  # OpenAI 兼容配置
  openai:
    # API 密钥（必填）
    # 可通过环境变量 LLM_API_KEY 覆盖
    api_key: "sk-xxxxxxxx"
    
    # API 基础 URL
    # 可通过环境变量 LLM_BASE_URL 覆盖
    # 百炼示例：
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
    # DeepSeek 示例：
    # base_url: "https://api.deepseek.com/v1"
    # OpenAI 原生：
    # base_url: "https://api.openai.com/v1"
    
    # 模型名称
    # 可通过环境变量 LLM_MODEL 覆盖
    # 百炼可选：qwen-turbo, qwen-plus, qwen-max, qwen-coder-plus
    # DeepSeek: deepseek-chat, deepseek-coder
    # OpenAI: gpt-4, gpt-3.5-turbo
    model: "qwen-turbo"

# 服务器配置
server:
  # 监听地址
  host: "0.0.0.0"
  
  # 监听端口
  port: 8000
  
  # 调试模式（开发时设为 true）
  debug: false
